@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using KeyVerse.Models
@{
    int cantidadCarrito = 0;
    var carritoJson = Context.Session.GetString("MiCarrito");
    if (!string.IsNullOrEmpty(carritoJson))
    {
        var lista = JsonSerializer.Deserialize<List<Juego>>(carritoJson);
        cantidadCarrito = lista.Count;
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KEYVERSE</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KEYVERSE.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark mb-4" style="background-color: #171a21; border-bottom: 2px solid #66c0f4; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index" style="color: #66c0f4; letter-spacing: 1px;">
                    🎮 KEYVERSE
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-area="" asp-controller="Home" asp-action="Index">Catálogo</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light" href="#">🔥 Ofertas Top</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item me-3">
                            <a class="nav-link text-warning fw-bold" href="/Home/Carrito">🛒 Mi Carrito (@cantidadCarrito)</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-info text-white btn-sm mt-1" href="#">Iniciar Sesión</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - KEYVERSE - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
