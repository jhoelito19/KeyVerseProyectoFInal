@model List<KeyVerse.Models.Juego>
@{
    ViewData["Title"] = "Catálogo - KeyVerse";
}

<style>
    /* 🎨 PALETA DARK VINTAGE */
    body {
        background-color: #121212 !important;
        color: #e4e4e4 !important;
        font-family: 'Courier New', Courier, monospace;
    }

    /* Banner Principal */
    .vintage-banner {
        background: linear-gradient(135deg, #0d0d0d 0%, #221f1d 100%);
        border-bottom: 2px solid #c5a059;
        padding: 4rem 2rem;
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.8);
        margin-bottom: 3rem;
    }

        .vintage-banner h1 {
            font-family: 'Georgia', serif;
            color: #c5a059;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 3px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.9);
        }

        .vintage-banner p {
            color: #a09d98;
            font-style: italic;
            font-size: 1.1rem;
        }

    /* Buscador Premium */
    .search-input {
        background-color: #1a1a1a;
        border: 1px solid #c5a059;
        color: #c5a059;
        font-family: 'Courier New', Courier, monospace;
    }

        .search-input:focus {
            background-color: #222;
            border-color: #dfb662;
            box-shadow: 0 0 10px rgba(197, 160, 89, 0.3);
            color: white;
        }

    .search-btn {
        background-color: #c5a059;
        color: #121212;
        border: 1px solid #c5a059;
        font-weight: bold;
        font-family: 'Georgia', serif;
        transition: all 0.3s ease;
    }

        .search-btn:hover {
            background-color: #dfb662;
            color: black;
            box-shadow: 0 0 15px rgba(223, 182, 98, 0.5);
        }

    /* Tarjetas (Cards) */
    .game-card {
        background-color: #1a1a1a !important;
        border: 1px solid #333 !important;
        border-radius: 8px;
        transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
        overflow: hidden;
    }

        .game-card:hover {
            transform: translateY(-5px);
            border-color: #c5a059 !important;
            box-shadow: 0 8px 25px rgba(197, 160, 89, 0.15) !important;
        }

    .card-title {
        color: #c5a059 !important;
        font-family: 'Georgia', serif;
        font-weight: bold;
        letter-spacing: 1px;
    }

    .stock-text {
        color: #8b8b8b;
        font-style: italic;
    }

    .precio-text {
        color: #e4e4e4;
        font-family: 'Georgia', serif;
        text-shadow: 1px 1px 2px black;
    }

    /* Botón Ver Detalles Vintage */
    .btn-vintage-outline {
        border: 1px solid #c5a059;
        color: #c5a059;
        background: transparent;
        font-family: 'Courier New', Courier, monospace;
        font-weight: bold;
        transition: all 0.3s ease;
    }

        .btn-vintage-outline:hover {
            background-color: #c5a059;
            color: #121212;
            box-shadow: 0 0 10px rgba(197, 160, 89, 0.4);
        }

    /* Contenedor Multimedia */
    .media-container {
        position: relative;
        height: 200px;
        background-color: #0d0d0d;
        border-bottom: 1px solid #333;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .game-card:hover .media-container {
        border-bottom: 1px solid #c5a059;
    }

    .hover-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.5s ease;
        z-index: 2;
    }

    .media-container:hover .hover-video {
        opacity: 1;
    }
</style>

<div class="container mt-4">

    <div class="vintage-banner text-center">
        <h1>Bienvenido a KeyVerse</h1>
        <p>Las mejores keys de activación, mods y software al instante.</p>

        <div class="row justify-content-center mt-4">
            <div class="col-md-8">
                <form asp-controller="Home" asp-action="Buscar" method="get" class="d-flex justify-content-center gap-2">
                    <input type="text" name="nombre" class="form-control search-input w-75" placeholder="Ej. Buscar juegos, mods..." value="@ViewBag.BusquedaActual">
                    <button type="submit" class="btn search-btn px-4">BUSCAR</button>
                </form>
            </div>
        </div>
    </div>

    <h3 class="mb-4 text-white" style="font-family: 'Georgia', serif; border-bottom: 1px solid #333; padding-bottom: 10px;">Catálogo Oficial en Stock</h3>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var juego in Model)
        {
            // --- MAGIA C#: IMÁGENES REALES O AUTOGENERADAS ---
            string urlImagen = "";
            if (!string.IsNullOrEmpty(juego.ImagenUrl) && juego.ImagenUrl.StartsWith("http"))
            {
                urlImagen = juego.ImagenUrl;
            }
            else
            {
                urlImagen = "https://picsum.photos/seed/" + juego.IdJuego + "/600/300";
            }

            // --- MAGIA C#: VIDEOS POR CATEGORÍA ---
            string urlVideo = "https://media.w3.org/2010/05/sintel/trailer.mp4";
            if (juego.IdCategoria == 1 || juego.IdCategoria == 7)
            {
                urlVideo = "https://storage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4";
            }
            else if (juego.IdCategoria == 4)
            {
                urlVideo = "https://storage.googleapis.com/gtv-videos-bucket/sample/ElephantsDream.mp4";
            }
            else if (juego.IdCategoria == 6 || juego.IdCategoria == 2)
            {
                urlVideo = "https://storage.googleapis.com/gtv-videos-bucket/sample/TearsOfSteel.mp4";
            }

            <div class="col">
                <div class="card h-100 game-card">

                    <div class="media-container"
                         style="background-image: url('@urlImagen'); background-size: cover; background-position: center;"
                         onmouseenter="var vid = this.querySelector('video'); vid.style.opacity = '1'; vid.play().catch(e => console.log(e));"
                         onmouseleave="var vid = this.querySelector('video'); vid.style.opacity = '0'; vid.pause(); vid.currentTime = 0;">

                        <video class="hover-video" loop muted playsinline>
                            <source src="@urlVideo" type="video/mp4">
                        </video>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <span class="badge mb-2 align-self-start" style="background-color: #333; color: #c5a059; border: 1px solid #c5a059;">Categoría #@juego.IdCategoria</span>
                        <h5 class="card-title">@juego.Nombre</h5>

                        <p class="card-text stock-text mt-auto">
                            ✓ En Stock: @juego.Stock unidades
                        </p>
                    </div>

                    <div class="card-footer bg-transparent border-0 d-flex justify-content-between align-items-center pb-3 pt-0">
                        <span class="fs-4 fw-bold precio-text">@juego.Precio.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("en-US"))</span>

                        <a href="/Home/Detalles?id=@juego.IdJuego" class="btn btn-vintage-outline btn-sm">🎮 Ver detalles</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>