@model List<KeyVerse.Models.Juego>
@{
    ViewData["Title"] = "Catálogo - KeyVerse";
}

<!-- Importamos FontAwesome para los íconos -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<style>
    /* 🎨 PALETA KEYVERSE */
    body {
        background-color: #121212 !important;
        color: #ffffff !important;
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    /* 🔥 EFECTO CRISTAL (STICKY + BLUR) */
    .top-search-wrapper {
        display: flex;
        justify-content: center;
        /* Hacemos que se quede pegado al hacer scroll */
        position: sticky;
        top: 20px;
        z-index: 1000;
        margin-top: 15px;
        margin-bottom: 30px;
    }

    .ig-search-container {
        /* Fondo gris semi-transparente */
        background-color: rgba(38, 38, 38, 0.65);
        /* Efecto de vidrio empañado (Blur) */
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        /* Borde súper sutil para resaltar el cristal */
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 40px;
        padding: 5px 5px 5px 25px;
        display: flex;
        align-items: center;
        gap: 20px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        width: 100%;
        max-width: 850px;
    }

    .ig-platforms {
        display: flex;
        gap: 20px;
        color: #b3b3b3;
        font-size: 0.95rem;
        font-weight: 500;
        border-right: 1px solid rgba(255, 255, 255, 0.2);
        padding-right: 20px;
    }

        .ig-platforms span {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            transition: color 0.2s;
        }

            .ig-platforms span:hover {
                color: #0099ff;
            }

    .ig-search-box {
        background-color: transparent;
        border: none;
        color: white;
        outline: none;
        width: 100%;
        font-size: 0.95rem;
    }

        .ig-search-box::placeholder {
            color: #bbb;
        }

    .ig-search-btn {
        background-color: #0099ff;
        border: none;
        border-radius: 50%;
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        transition: background-color 0.2s, transform 0.2s;
        flex-shrink: 0;
    }

        .ig-search-btn:hover {
            background-color: #007acc;
            transform: scale(1.05);
        }

    /* Hero Banner Principal */
    .ig-hero {
        position: relative;
        height: 350px;
        border-radius: 12px;
        overflow: hidden;
        background: url('https://images.unsplash.com/photo-1542751371-adc38448a05e?auto=format&fit=crop&w=2070&q=80') no-repeat center center/cover;
        display: flex;
        align-items: center;
        margin-bottom: 50px;
    }

    .ig-hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, rgba(18,18,18,1) 0%, rgba(18,18,18,0.6) 40%, rgba(18,18,18,0) 100%);
        z-index: 1;
    }

    .ig-hero-content {
        position: relative;
        z-index: 2;
        padding: 50px;
        width: 100%;
    }

    .ig-hero-title {
        font-size: 3rem;
        font-weight: bold;
        margin-bottom: 15px;
        text-shadow: 2px 2px 10px rgba(0,0,0,0.8);
    }

    .ig-discount {
        background-color: #0099ff;
        color: white;
        padding: 4px 12px;
        border-radius: 4px;
        font-weight: bold;
        font-size: 1.2rem;
        margin-right: 15px;
    }

    .ig-price {
        font-size: 2.5rem;
        font-weight: bold;
        text-shadow: 1px 1px 5px rgba(0,0,0,0.8);
    }

    /* Sección Tendencias */
    .section-title {
        font-size: 1.6rem;
        font-weight: 600;
        margin-bottom: 25px;
    }

        .section-title i {
            color: #666;
            font-size: 1.2rem;
            margin-left: 10px;
        }

    /* Tarjetas de Juegos (Cards) */
    .ig-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .ig-card {
        background: transparent !important;
        border: none !important;
        transition: transform 0.2s;
    }

        .ig-card:hover {
            transform: translateY(-5px);
        }

    .media-container {
        position: relative;
        height: 220px;
        border-radius: 12px;
        overflow: hidden;
        background-color: #1a1a1a;
        box-shadow: 0 4px 15px rgba(0,0,0,0.4);
    }

    .hover-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.4s ease;
        z-index: 2;
    }

    .media-container:hover .hover-video {
        opacity: 1;
    }

    .card-price-tag {
        position: absolute;
        bottom: 10px;
        left: 10px;
        background: rgba(0,0,0,0.8);
        padding: 5px 12px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 1.1rem;
        z-index: 3;
        backdrop-filter: blur(4px);
    }

    .ig-card-info {
        padding: 15px 5px;
    }

    .ig-card-title {
        font-size: 1.1rem;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin: 0;
        color: #e6e6e6;
        transition: color 0.2s;
    }

    .ig-card:hover .ig-card-title {
        color: #0099ff;
    }

    .ig-stock {
        font-size: 0.85rem;
        color: #888;
        margin-top: 5px;
    }
</style>

<div class="container mt-2">

    <!-- Buscador Flotante y de Cristal -->
    <div class="top-search-wrapper">
        <form asp-controller="Home" asp-action="Buscar" method="get" class="ig-search-container">

            <div class="ig-platforms d-none d-md-flex">
                <span><i class="fa-solid fa-desktop"></i> PC</span>
                <span><i class="fa-brands fa-playstation"></i> PlayStation</span>
                <span><i class="fa-brands fa-xbox"></i> Xbox</span>
                <span><i class="fa-solid fa-gamepad"></i> Nintendo</span>
            </div>

            <input type="text" name="nombre" class="ig-search-box" placeholder="Buscar en el catálogo..." value="@ViewBag.BusquedaActual">

            <button type="submit" class="ig-search-btn">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </form>
    </div>

    <!-- Hero Banner -->
    <div class="ig-hero">
        <div class="ig-hero-overlay"></div>
        <div class="ig-hero-content">
            <h1 class="ig-hero-title">KeyVerse Premium</h1>
            <div class="d-flex align-items-center mt-3">
                <span class="ig-discount">-31%</span>
                <span class="ig-price">$48.59</span>
            </div>
        </div>
    </div>

    <h3 class="section-title">
        Catálogo en Stock <i class="fa-solid fa-chevron-right"></i>
    </h3>

    <!-- Grilla de Juegos -->
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-5">
        @foreach (var juego in Model)
        {
            string urlImagen = (!string.IsNullOrEmpty(juego.ImagenUrl) && juego.ImagenUrl.StartsWith("http")) ? juego.ImagenUrl : "https://picsum.photos/seed/" + juego.IdJuego + "/600/300";

            string urlVideo = "https://media.w3.org/2010/05/sintel/trailer.mp4";
            if (juego.IdCategoria == 1 || juego.IdCategoria == 7) urlVideo = "https://storage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4";
            else if (juego.IdCategoria == 4) urlVideo = "https://storage.googleapis.com/gtv-videos-bucket/sample/ElephantsDream.mp4";
            else if (juego.IdCategoria == 6 || juego.IdCategoria == 2) urlVideo = "https://storage.googleapis.com/gtv-videos-bucket/sample/TearsOfSteel.mp4";

            <div class="col">
                <a href="/Home/Detalles?id=@juego.IdJuego" class="ig-card-link">
                    <div class="ig-card">

                        <div class="media-container"
                             style="background-image: url('@urlImagen'); background-size: cover; background-position: center;"
                             onmouseenter="var vid = this.querySelector('video'); vid.style.opacity = '1'; vid.play().catch(e => console.log(e));"
                             onmouseleave="var vid = this.querySelector('video'); vid.style.opacity = '0'; vid.pause(); vid.currentTime = 0;">

                            <div class="card-price-tag">@juego.Precio.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("en-US"))</div>

                            <video class="hover-video" loop muted playsinline>
                                <source src="@urlVideo" type="video/mp4">
                            </video>
                        </div>

                        <div class="ig-card-info">
                            <h5 class="ig-card-title">@juego.Nombre</h5>
                            <p class="ig-stock"><i class="fa-solid fa-check text-success"></i> Stock: @juego.Stock</p>
                        </div>

                    </div>
                </a>
            </div>
        }
    </div>
</div>